import os
import pandas as pd

configfile: "config/config.yaml"

SAMPLES = pd.read_csv(config["samples"], index_col="sample", sep='\t')
print(SAMPLES.index)
REF_BASENAME = "reference"

include: "rules/qc.smk"
include: "rules/trimming.smk"
include: "rules/star.smk"
include: "rules/feature_counts.smk"
include: "rules/samtools.smk"
include: "rules/variability.smk"
include: "rules/denovo.smk"

rule all:
    input:
        expand("results/star/pe/{sample}/{sample}_aligned.bam", sample=SAMPLES.index),
        "results/featureCounts/all.featureCounts",
        "results/plots/top_variable_genes_heatmap.pdf",
        
        "results/qc/multiqc_all.html" if not config["analysis_options"]["skip_fastQC"]==True else [],

        directory("results/trinity_out_dir/"),
        
		
rule multiqc_all:
    input:
        # FastQC reports
        expand("results/qc/fastqc/raw/{sample}_{read}_fastqc.zip", sample=SAMPLES.index, read=['1', '2']),
        expand("results/qc/fastqc/processed/{sample}_{read}_fastqc.zip", sample=SAMPLES.index, read=['1', '2']),
        
        # Qualimap reports
        expand("results/qc/qualimap/{sample}", sample=SAMPLES.index) if not config["analysis_options"]["skip_qualimap"]==True else [],
        
    output:
        report_file="results/qc/multiqc_all.html",
        out_dir=directory("results/qc/multiqc_all_data")

    log:
        "logs/multiqc/all.log"
    conda:
        "envs/qc.yaml"
    shell:
        """
        multiqc {input} \
            --filename multiqc_all.html \
            --outdir results/qc \
            > {log} 2>&1
        """

